{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "scrcpy-mac-ui",
  "version": "0.1.0",
  "identifier": "com.scrcpy.controller",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "scrcpy Controller",
        "width": 420,
        "height": 640,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"]
  }
}
